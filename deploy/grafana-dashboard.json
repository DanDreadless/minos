{
  "__comment": "Minos dashboard. Import in Grafana (Dashboards -> New -> Import), pick your Prometheus datasource, done. Pairs with the scrape config in docs/getting-started.md.",
  "title": "Minos — every query gets judged",
  "uid": "minos-dns",
  "tags": ["minos", "dns"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Block rate",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * minos_queries_blocked_total / minos_queries_total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "dark-red" } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cache hit rate",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * minos_cache_hits_total / (minos_cache_hits_total + minos_cache_misses_total)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Devices seen",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "minos_devices_seen" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Block rules",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sum(minos_rules{type=\"deny\"})" }],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Blocking",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "minos_blocking_paused" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Active", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Paused", "color": "orange" } } }
          ],
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Sick upstreams",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sum(minos_upstream_sick)" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Query rate",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "rate(minos_queries_total[$__rate_interval])", "legendFormat": "queries" },
        { "refId": "B", "expr": "rate(minos_queries_blocked_total[$__rate_interval])", "legendFormat": "blocked" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 12 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "blocked" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cache",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "rate(minos_cache_hits_total[$__rate_interval])", "legendFormat": "hits" },
        { "refId": "B", "expr": "rate(minos_cache_misses_total[$__rate_interval])", "legendFormat": "misses" },
        { "refId": "C", "expr": "minos_cache_entries", "legendFormat": "entries" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 12 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "entries" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Upstream mean latency",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(minos_upstream_duration_seconds_total[$__rate_interval]) / rate(minos_upstream_requests_total[$__rate_interval])",
          "legendFormat": "{{upstream}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 8 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Upstream failures",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(minos_upstream_failures_total[$__rate_interval])",
          "legendFormat": "{{upstream}} failures"
        },
        { "refId": "B", "expr": "minos_upstream_sick", "legendFormat": "{{upstream}} sick" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 12 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Rules per blocklist",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "minos_list_rules", "legendFormat": "{{list}}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "continuous-GrYlRd" } },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Query-log entries dropped",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(minos_querylog_dropped_total[$__rate_interval])",
          "legendFormat": "dropped"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 12 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
